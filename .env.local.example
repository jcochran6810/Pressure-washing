# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_anon_key
# Service-role key (NEVER commit this; required for Stripe webhook + cron jobs)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Stripe (online invoice payments)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Resend (transactional email — receipts, invoices, estimates)
RESEND_API_KEY=re_replace_me
RESEND_FROM="Your Business <noreply@yourdomain.com>"

# Telnyx (SMS — estimates, invoices, receipts, reminders, waivers)
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+15555550100

# Google OAuth (Drive integration — invoices/photos backup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (satellite measurement tool)
# Enable: Maps JavaScript API, Drawing, Geometry, Places, Geocoding
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# QuickBooks Online (live accounting sync)
# Create an app at https://developer.intuit.com and set redirect to:
#   $NEXT_PUBLIC_APP_URL/api/accounting/qbo/callback
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_ENVIRONMENT=sandbox

# Cron auth (reminders + contracts background jobs)
CRON_SECRET=

# App base URL (used for OAuth redirects + webhook callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SaaS subscription billing
# Pre-create a Price in your Stripe Dashboard and paste the ID here.
# Without it the app will create a $49/mo product on first checkout.
STRIPE_SUBSCRIPTION_PRICE_ID=

# From-address for SaaS-level emails (trial endings, payment failures).
# Falls back to RESEND_FROM if unset.
SAAS_EMAIL_FROM="Suds <billing@yourdomain.com>"

# Sentry error monitoring (optional; if unset, Sentry is inert)
NEXT_PUBLIC_SENTRY_DSN=
# Required only to upload source maps from CI:
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
